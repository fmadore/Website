{
	"name": "frederick-madore-website",
	"private": true,
	"version": "2.1.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"prebuild": "npm run gen:refs",
		"preview": "vite preview",
		"gen:refs": "node scripts/generate-reference-index.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:tsgo": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"serve:https": "npx serve build -l 8080 --ssl-cert localhost.pem --ssl-key localhost-key.pem"
	},
	"devDependencies": {
		"@csstools/postcss-global-data": "^4.0.0",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/d3": "^7.4.3",
		"@types/node": "^26.0.0",
		"@typescript/native-preview": "^7.0.0-dev.20260707.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"postcss": "^8.5.21",
		"postcss-custom-media": "^12.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"serve": "^14.2.6",
		"sharp": "^0.35.3",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"overrides": {
		"js-yaml": ">=4.1.1",
		"devalue": ">=5.8.1",
		"brace-expansion": ">=5.0.7",
		"echarts-wordcloud": {
			"echarts": "$echarts"
		},
		"dompurify": "^3.4.12",
		"fast-uri": "^3.1.4",
		"cookie": ">=0.7.0",
		"protocol-buffers-schema": ">=3.6.1"
	},
	"dependencies": {
		"@iconify-icons/academicons": "^1.2.10",
		"@iconify-icons/lucide": "^1.2.135",
		"@iconify-icons/mdi": "^1.2.48",
		"@iconify-icons/simple-icons": "^1.2.74",
		"@iconify/svelte": "^5.2.2",
		"d3": "^7.9.0",
		"echarts": "^6.1.0",
		"echarts-wordcloud": "^2.1.0",
		"jspdf": "^4.2.1",
		"maplibre-gl": "^5.24.0"
	}
}
