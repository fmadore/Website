{
	"name": "frederick-madore-website",
	"private": true,
	"version": "2.1.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"build:pwa": "npm run build && npm run pwa:validate",
		"pwa:validate": "echo '✅ PWA built successfully - check Lighthouse for PWA score'",
		"serve:https": "npx serve build -l 8080 --ssl-cert localhost.pem --ssl-key localhost-key.pem"
	},
	"devDependencies": {
		"@csstools/postcss-global-data": "^4.0.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"mdsvex": "^0.12.6",
		"postcss": "^8.5.12",
		"postcss-custom-media": "^12.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.9"
	},
	"overrides": {
		"js-yaml": ">=4.1.1",
		"devalue": ">=5.6.4",
		"echarts-wordcloud": {
			"echarts": "$echarts"
		},
		"dompurify": "^3.4.0",
		"cookie": ">=0.7.0",
		"protocol-buffers-schema": ">=3.6.1"
	},
	"dependencies": {
		"@iconify-icons/academicons": "^1.2.10",
		"@iconify-icons/lucide": "^1.2.135",
		"@iconify-icons/mdi": "^1.2.48",
		"@iconify-icons/simple-icons": "^1.2.74",
		"@iconify/svelte": "^5.2.1",
		"@types/d3": "^7.4.3",
		"d3": "^7.9.0",
		"echarts": "^6.0.0",
		"echarts-wordcloud": "^2.1.0",
		"jspdf": "^4.2.1",
		"maplibre-gl": "^5.24.0"
	}
}
